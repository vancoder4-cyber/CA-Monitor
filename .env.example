# 复制为 .env 并填入你的 key。免费申请地址见 README。
ALPHAVANTAGE=your_alphavantage_key
FMP=your_fmp_key
FINNHUB=your_finnhub_key
TIINGO=your_tiingo_token
ALPACA_KEY_ID=your_alpaca_key_id
ALPACA_SECRET=your_alpaca_secret
SEC_UA=ca-monitor your_email@example.com

# FINX / TRKD-HS 静态数据 API(第 8 源,可选;留空则跳过该源)
# 接口仍在调整中(供方约 2 周、demo 阶段)。凭证只放这里/环境变量,勿写进代码。
FINX_USER=
FINX_PASS=
# 正式环境留空即用默认;UAT 用:https://finx.uat.platform.trkd-hs.com/finx-api
FINX_BASE=

# Lark 自定义机器人推送(可选)
LARK_WEBHOOK=https://open.larksuite.com/open-apis/bot/v2/hook/xxxxxxxx
LARK_SECRET=
LARK_DASHBOARD_URL=
LARK_NOTIFY_EMPTY=0

# 人工确认写回(交互机器人「确认」指令需要;配在 Railway):
# 细粒度 PAT,只对本仓库 Contents 勾选 Read and write;其它一律不勾。
GH_TOKEN=
GH_REPO=vancoder4-cyber/CA-Monitor
GH_BRANCH=main
