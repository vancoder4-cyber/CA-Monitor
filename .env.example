# 复制为 .env 并填入你的 key。免费申请地址见 README。
ALPHAVANTAGE=your_alphavantage_key
FMP=your_fmp_key
FINNHUB=your_finnhub_key
TIINGO=your_tiingo_token
ALPACA_KEY_ID=your_alpaca_key_id
ALPACA_SECRET=your_alpaca_secret
SEC_UA=ca-monitor your_email@example.com

# Lark 自定义机器人推送(可选)
LARK_WEBHOOK=https://open.larksuite.com/open-apis/bot/v2/hook/xxxxxxxx
LARK_SECRET=
LARK_DASHBOARD_URL=
LARK_NOTIFY_EMPTY=0
